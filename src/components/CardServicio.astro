---
export interface Props {
  icon: string;       // SVG path data (stroke)
  title: string;
  description: string;
  tags?: string[];
  featured?: boolean;
}

const { icon, title, description, tags = [], featured = false } = Astro.props;
---

<article
  class:list={[
    'group relative flex flex-col gap-4 rounded-lg border p-6 transition-all duration-300',
    'hover:-translate-y-1 hover:shadow-glow-sm',
    featured
      ? 'border-electric/50 bg-electric/5 hover:border-electric hover:bg-electric/10'
      : 'border-surface-200 bg-surface-50 hover:border-electric/40 hover:bg-surface-100',
  ]}
>
  <!-- Corner accent -->
  <span
    class:list={[
      'absolute top-0 right-0 h-px w-16 transition-all duration-300',
      featured ? 'bg-electric' : 'bg-surface-200 group-hover:bg-electric/60',
    ]}
    aria-hidden="true"
  ></span>

  <!-- Icon -->
  <div
    class:list={[
      'flex h-11 w-11 items-center justify-center rounded border transition-colors duration-300',
      featured
        ? 'border-electric/60 bg-electric/15 text-electric-light'
        : 'border-surface-200 bg-surface-100 text-slate-400 group-hover:border-electric/50 group-hover:text-electric-light',
    ]}
  >
    <svg
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <Fragment set:html={icon} />
    </svg>
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-2">
    <h3 class="font-semibold text-white leading-snug">{title}</h3>
    <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
  </div>

  <!-- Tags -->
  {tags.length > 0 && (
    <ul class="flex flex-wrap gap-2 mt-auto pt-2 border-t border-surface-200" aria-label="Tecnologías">
      {tags.map(tag => (
        <li class="font-mono text-xs px-2 py-0.5 rounded bg-surface-100 text-electric-glow border border-surface-200">
          {tag}
        </li>
      ))}
    </ul>
  )}
</article>
