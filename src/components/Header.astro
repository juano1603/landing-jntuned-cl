---
const navLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Tech Stack', href: '#tech-stack' },
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Soporte', href: '#contacto' },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between gap-8">

      <!-- Logo -->
      <a href="/" class="flex h-full items-center flex-shrink-0" aria-label="JNTUNED inicio">
        <img
          src="/logo-jntuned.png"
          alt="JNTUNED"
          class="h-8 w-auto max-w-[180px] object-contain transition-opacity duration-200 hover:opacity-80 mix-blend-screen"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="px-3 py-1.5 text-sm font-medium text-slate-400 rounded transition-colors duration-150 hover:text-white hover:bg-surface-100"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a
        href="#contacto"
        class="hidden sm:inline-flex items-center gap-2 rounded border border-electric bg-electric/10 px-4 py-2 text-sm font-semibold text-electric-light transition-all duration-200 hover:bg-electric hover:text-white hover:shadow-glow-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-electric"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
        </svg>
        Agendar Scan
      </a>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden flex items-center justify-center h-9 w-9 rounded border border-surface-200 text-slate-400 hover:text-white hover:border-slate-500 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <svg id="icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-surface-100 bg-surface/95 backdrop-blur-md"
    aria-label="Menú móvil"
  >
    <nav class="flex flex-col gap-1 px-4 py-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-link px-3 py-2.5 text-sm font-medium text-slate-300 rounded hover:text-white hover:bg-surface-100 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contacto"
        class="mobile-link mt-2 flex items-center justify-center gap-2 rounded border border-electric bg-electric/10 px-4 py-2.5 text-sm font-semibold text-electric-light hover:bg-electric hover:text-white transition-all"
      >
        Agendar Scan
      </a>
    </nav>
  </div>
</header>

<script>
  // Scroll → glassmorphism
  const header = document.getElementById('header') as HTMLElement;
  const onScroll = () => {
    const scrolled = window.scrollY > 20;
    header.setAttribute('data-scrolled', String(scrolled));
    if (scrolled) {
      header.classList.add('bg-surface/80', 'backdrop-blur-md', 'border-b', 'border-surface-100', 'shadow-lg');
    } else {
      header.classList.remove('bg-surface/80', 'backdrop-blur-md', 'border-b', 'border-surface-100', 'shadow-lg');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement;
  const menu   = document.getElementById('mobile-menu') as HTMLElement;
  const iconOpen  = document.getElementById('icon-open') as SVGElement;
  const iconClose = document.getElementById('icon-close') as SVGElement;

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    iconOpen.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });

  // Cerrar menú al click en link
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
