<script>
  // ── Form validation ──────────────────────────────────────────────────────
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successBanner = document.getElementById('form-success') as HTMLElement;
  const errorBanner   = document.getElementById('form-error') as HTMLElement;

  type FieldConfig = {
    id: string;
    errorId: string;
    validate: (val: string) => string | null;
  };

  const fields: FieldConfig[] = [
    {
      id: 'nombre',
      errorId: 'nombre-error',
      validate: v => v.trim().length < 2 ? 'Ingresa tu nombre (mínimo 2 caracteres).' : null,
    },
    {
      id: 'vehiculo',
      errorId: 'vehiculo-error',
      validate: v => v.trim().length < 3 ? 'Describe tu vehículo/motor.' : null,
    },
    {
      id: 'servicio',
      errorId: 'servicio-error',
      validate: v => !v ? 'Selecciona un servicio.' : null,
    },
    {
      id: 'mensaje',
      errorId: 'mensaje-error',
      validate: v => v.trim().length < 20 ? 'Describe tu proyecto con más detalle (mínimo 20 caracteres).' : null,
    },
  ];

  function showError(field: FieldConfig, msg: string) {
    const input = document.getElementById(field.id) as HTMLElement;
    const errorEl = document.getElementById(field.errorId) as HTMLElement;
    input.setAttribute('aria-invalid', 'true');
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function clearError(field: FieldConfig) {
    const input = document.getElementById(field.id) as HTMLElement;
    const errorEl = document.getElementById(field.errorId) as HTMLElement;
    input.setAttribute('aria-invalid', 'false');
    errorEl.classList.add('hidden');
  }

  // Live validation on blur
  fields.forEach(field => {
    const input = document.getElementById(field.id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
    input.addEventListener('blur', () => {
      const err = field.validate(input.value);
      err ? showError(field, err) : clearError(field);
    });
    input.addEventListener('input', () => {
      if (input.getAttribute('aria-invalid') === 'true') {
        const err = field.validate(input.value);
        err ? showError(field, err) : clearError(field);
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successBanner.classList.add('hidden');
    errorBanner.classList.add('hidden');

    let valid = true;
    fields.forEach(field => {
      const input = document.getElementById(field.id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
      const err = field.validate(input.value);
      if (err) { showError(field, err); valid = false; }
      else { clearError(field); }
    });

    if (!valid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando…';

    try {
      const formData = new FormData(form);
      const res = await fetch('https://formspree.io/f/REEMPLAZA_CON_TU_ID', {
        method: 'POST',
        body: formData,
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) throw new Error('Error');
      successBanner.classList.remove('hidden');
      form.reset();
    } catch {
      errorBanner.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Enviar cotización`;
    }
  });

  // ── Intersection Observer: animate cards on scroll ────────────────────
  const cards = document.querySelectorAll('article, li');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.opacity = '1';
          (entry.target as HTMLElement).style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  cards.forEach(card => {
    (card as HTMLElement).style.opacity = '0';
    (card as HTMLElement).style.transform = 'translateY(16px)';
    (card as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(card);
  });
</script>
