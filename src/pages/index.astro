---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CardServicio from '../components/CardServicio.astro';

const servicios = [
  {
    icon: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>', // bolt
    title: 'Gestión de ECUs',
    description: 'Seteo, calibración y mapeo de ECUs FuelTech FT300/FT450, Tactrix OpenPort y RaceTec. Tune en banco dinamométrico o ruta.',
    tags: ['FuelTech', 'Tactrix', 'RaceTec', 'OpenECU'],
    featured: true,
  },
  {
    icon: '<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>',
    title: 'Engine Swaps & Arneses',
    description: 'Conversiones SR20 y EJ20 con integración electrónica completa. Fabricación de arneses a medida, adaptación de protocolos CAN y OBD.',
    tags: ['SR20', 'EJ20', 'CAN Bus', 'Arneses'],
    featured: false,
  },
  {
    icon: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
    title: 'Diagnóstico & Logueo',
    description: 'Lectura avanzada con datalog multicanal. Análisis de knock, AFR, boost y temperatura. Reportes exportables y seguimiento post-tune.',
    tags: ['Datalog', 'WBO2', 'Knock', 'ECUMaster'],
    featured: false,
  },
  {
    icon: '<path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 8v4l3 3"/>',
    title: 'Upgrade de Hardware',
    description: 'Instalación y calibración de turbos, intercoolers, inyectores de alta impedancia y sistemas de combustible. Integración mecánica–electrónica.',
    tags: ['Turbo', 'Inyectores', 'Fuel System', 'Intercooler'],
    featured: false,
  },
];

const techStack = [
  {
    name: 'FuelTech FT450',
    category: 'ECU Manager',
    description: 'Control total de motor con datalog en tiempo real, launch control y traction control integrado.',
    img: '/tools/fueltech.png',
    featured: true,
  },
  {
    name: 'HP Tuners',
    category: 'Flash & Calibración',
    description: 'Plataforma profesional para lectura, modificación y logging de ECUs de fábrica GM, Ford, Dodge y más.',
    img: '/tools/hptuners.png',
    featured: true,
  },
  {
    name: 'Tactrix OpenPort 2.0',
    category: 'Flash & Log',
    description: 'Interfaz de flasheo y datalog para ECUs Subaru, Mitsubishi y otros protocolos OBD.',
    img: '/tools/tactrix.png',
    featured: false,
  },
  {
    name: 'RaceTec EMS',
    category: 'ECU Standalone',
    description: 'Sistema de gestión de motor standalone de alta precisión para aplicaciones de competición.',
    img: '/tools/racetec.png',
    featured: false,
  },
  {
    name: 'Knock Sensor TunerNerd',
    category: 'Detección de Knock',
    description: 'Monitoreo de detonación en tiempo real con análisis de frecuencia por cilindro.',
    img: '/tools/tunernerd.png',
    featured: false,
  },
];
---

<Layout>
  <Header />

  <main class="overflow-x-hidden">

    <!-- ═══════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════ -->
    <section
      id="hero"
      class="relative flex min-h-screen flex-col items-center justify-center px-4 pt-16 text-center"
      aria-labelledby="hero-heading"
    >
      <!-- Background grid + glow -->
      <div class="pointer-events-none absolute inset-0 bg-grid-dark bg-grid opacity-100" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
      <!-- Ambient orb -->
      <div class="pointer-events-none absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 h-96 w-96 rounded-full bg-electric/10 blur-3xl animate-pulse-slow" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto max-w-4xl flex flex-col items-center gap-6">
        <!-- Eyebrow badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-electric/30 bg-electric/10 px-4 py-1.5 text-xs font-mono font-medium tracking-widest text-electric-glow uppercase">
          <span class="h-1.5 w-1.5 rounded-full bg-electric-light animate-pulse" aria-hidden="true"></span>
          Temuco, Chile · Performance Automotriz
        </div>

        <!-- Heading -->
        <h1
          id="hero-heading"
          class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl"
        >
          Performance de precisión:
          <br />
          <span class="bg-gradient-to-r from-electric-light via-electric-bright to-electric-glow bg-clip-text text-transparent">
            Ingeniería aplicada
          </span>
          {' '}a tu motor.
        </h1>

        <!-- Subheadline -->
        <p class="max-w-2xl text-base sm:text-lg text-slate-400 leading-relaxed">
          Expertos en seteo de ECUs <span class="font-mono text-electric-glow">FuelTech</span> y <span class="font-mono text-electric-glow">RaceTec</span>.
          Engine Swaps con integración electrónica de fábrica en Temuco.
          Diagnóstico real, datos reales, resultados medibles.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mt-2">
          <a
            href="#contacto"
            class="inline-flex items-center justify-center gap-2 rounded bg-electric px-6 py-3 text-sm font-semibold text-white shadow-glow-blue transition-all duration-200 hover:bg-electric-light hover:shadow-glow-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-electric"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            Cotizar mi Proyecto
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 rounded border border-surface-200 px-6 py-3 text-sm font-medium text-slate-300 transition-all duration-200 hover:border-slate-500 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-500"
          >
            Ver Servicios
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Stats bar -->
        <dl class="mt-8 flex flex-wrap justify-center gap-x-8 gap-y-4 border-t border-surface-100 pt-8">
          {[
            { value: '+150', label: 'ECUs calibradas' },
            { value: '100%', label: 'Datalog verificado' },
          ].map(stat => (
            <div class="flex flex-col items-center gap-1">
              <dt class="font-mono text-2xl font-bold text-white">{stat.value}</dt>
              <dd class="text-xs text-slate-500 uppercase tracking-wider">{stat.label}</dd>
            </div>
          ))}
        </dl>
      </div>

    </section>

    <!-- ═══════════════════════════════════════════════
         SERVICIOS
    ═══════════════════════════════════════════════ -->
    <section
      id="servicios"
      class="relative px-4 py-24 sm:py-32"
      aria-labelledby="servicios-heading"
    >
      <div class="mx-auto max-w-7xl">
        <!-- Section header -->
        <header class="mb-14 flex flex-col gap-3">
          <span class="font-mono text-xs font-medium uppercase tracking-widest text-electric-light">
            // Servicios
          </span>
          <h2 id="servicios-heading" class="text-3xl font-bold text-white sm:text-4xl">
            Soluciones técnicas de alto rendimiento
          </h2>
          <p class="max-w-xl text-slate-400">
            Cada intervención está respaldada por instrumentación de medición y procesos documentados.
            Nada se hace de memoria, todo se verifica con datos.
          </p>
        </header>

        <!-- Grid -->
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {servicios.map(s => (
            <CardServicio
              icon={s.icon}
              title={s.title}
              description={s.description}
              tags={s.tags}
              featured={s.featured}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         TECH STACK
    ═══════════════════════════════════════════════ -->
    <section
      id="tech-stack"
      class="relative border-y border-surface-100 bg-surface-50 px-4 py-24 sm:py-32"
      aria-labelledby="tech-heading"
    >
      <!-- Decorative line -->
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent" aria-hidden="true"></div>

      <div class="mx-auto max-w-7xl">
        <header class="mb-14 flex flex-col gap-3">
          <span class="font-mono text-xs font-medium uppercase tracking-widest text-electric-light">
            // Tech Stack
          </span>
          <h2 id="tech-heading" class="text-3xl font-bold text-white sm:text-4xl">
            Herramientas que usamos a diario
          </h2>
          <p class="max-w-xl text-slate-400">
            Trabajamos exclusivamente con equipamiento de nivel profesional.
            Sin atajos, sin herramientas genéricas.
          </p>
        </header>

        <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5" role="list">
          {techStack.map(tool => (
            <li class:list={[
              'group flex flex-col rounded-xl border overflow-hidden transition-all duration-300 hover:-translate-y-1',
              tool.featured
                ? 'border-electric/40 bg-electric/5 hover:border-electric hover:shadow-glow-sm'
                : 'border-surface-200 bg-surface hover:border-electric/30 hover:bg-surface-50',
            ]}>
              <!-- Imagen -->
              <div class="relative flex items-center justify-center bg-surface-100 h-44 overflow-hidden">
                <img
                  src={tool.img}
                  alt={tool.name}
                  class="h-28 w-auto max-w-[80%] object-contain mix-blend-screen transition-transform duration-300 group-hover:scale-105"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <!-- Fallback si no hay imagen -->
                <div class="hidden absolute inset-0 items-center justify-center">
                  <span class="font-mono text-xs text-slate-600 uppercase tracking-widest px-4 text-center">{tool.name}</span>
                </div>
                <!-- Overlay degradado inferior -->
                <div class="absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-surface-100 to-transparent"></div>
              </div>

              <!-- Info -->
              <div class="flex flex-col gap-2 p-5">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-mono text-sm font-semibold text-white leading-snug group-hover:text-electric-light transition-colors">
                    {tool.name}
                  </h3>
                  {tool.featured && (
                    <span class="flex-shrink-0 rounded-full bg-electric/20 border border-electric/30 px-2 py-0.5 text-[10px] font-mono font-medium text-electric-glow uppercase tracking-wider">
                      Pro
                    </span>
                  )}
                </div>
                <span class="text-xs text-slate-600 uppercase tracking-wider">{tool.category}</span>
                <p class="text-xs text-slate-400 leading-relaxed mt-1">{tool.description}</p>
              </div>
            </li>
          ))}
        </ul>

      </div>

      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent" aria-hidden="true"></div>
    </section>

    <!-- ═══════════════════════════════════════════════
         PROYECTOS (placeholder)
    ═══════════════════════════════════════════════ -->
    <section
      id="proyectos"
      class="px-4 py-24 sm:py-32"
      aria-labelledby="proyectos-heading"
    >
      <div class="mx-auto max-w-7xl">
        <header class="mb-14 flex flex-col gap-3">
          <span class="font-mono text-xs font-medium uppercase tracking-widest text-electric-light">
            // Proyectos
          </span>
          <h2 id="proyectos-heading" class="text-3xl font-bold text-white sm:text-4xl">
            Builds recientes
          </h2>
          <p class="max-w-xl text-slate-400">
            Cada vehículo que pasa por JNTUNED tiene un expediente técnico completo.
            Los resultados hablan por sí solos.
          </p>
        </header>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              vehiculo: 'Nissan Primera P11',
              motor: 'SR20DE + Apex\'i SAFC',
              servicio: 'Seteo de corte de combustible y ajuste de mapas vía SAFC. Preparación para competencia en pista de arrastre.',
              gain: '10.13 s 1/8 milla',
              tag: 'Drag Race',
            },
            {
              vehiculo: 'Subaru Legacy GT',
              motor: 'EJ20 · FuelTech FT450',
              servicio: 'Calibración completa con FuelTech FT450 y monitoreo de detonación en tiempo real con TunerNerd Knock Monitor.',
              gain: 'Seteo sin margen de error',
              tag: 'Tune & Datalog',
            },
            {
              vehiculo: 'Subaru Impreza WRX',
              motor: 'EJ20T · ECU stock',
              servicio: 'Reprogramación con Tactrix OpenPort + ECUFlash. Optimización de mapas de combustible e ignición.',
              gain: 'Stage 1 completo',
              tag: 'ECU Flash',
            },
            {
              vehiculo: 'Mitsubishi Lancer Evolution',
              motor: '4G63T · ECU stock',
              servicio: 'Extracción del máximo potencial vía Tactrix + EvoScan. Optimización de mapas de combustible, encendido y monitoreo de sensores críticos.',
              gain: 'Potencial máximo ECU',
              tag: 'Tune & Monitoreo',
            },
            {
              vehiculo: 'Subaru Legacy GT-B BP5',
              motor: 'EJ20X/Y · Dual AVCS · Twin-Scroll',
              servicio: 'Diagnóstico y calibración del sistema Dual AVCS y turbo Twin-Scroll. Plataforma de laboratorio para desarrollo de tune avanzado.',
              gain: 'MY04 · Car of the Year Japan',
              tag: 'Diagnóstico Avanzado',
            },
            {
              vehiculo: 'Suzuki Swift GTI',
              motor: 'SR20VE · Nismotronic',
              servicio: 'Engine swap SR20VE con instalación y seteo de gestión Nismotronic. Integración electrónica completa sobre motor de alta compresión.',
              gain: 'Gestión standalone',
              tag: 'Engine Management',
            },
          ].map(p => (
            <article class="group flex flex-col rounded-lg border border-surface-200 bg-surface-50 p-6 transition-all hover:border-electric/40 hover:-translate-y-1 hover:shadow-glow-sm">
              <div class="mb-4 flex items-center justify-between gap-2">
                <span class="rounded border border-surface-200 bg-surface px-2 py-0.5 font-mono text-[10px] text-slate-500 uppercase tracking-wider">
                  {p.tag}
                </span>
                <span class="rounded-full bg-electric/10 border border-electric/20 px-2 py-0.5 font-mono text-[10px] text-electric-glow text-right">
                  {p.gain}
                </span>
              </div>
              <h3 class="font-bold text-white text-base mb-0.5">{p.vehiculo}</h3>
              <p class="font-mono text-xs text-electric-light mb-3">{p.motor}</p>
              <p class="text-sm text-slate-400 leading-relaxed">{p.servicio}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         INSTAGRAM
    ═══════════════════════════════════════════════ -->
    <section
      id="instagram"
      class="relative border-t border-surface-100 bg-surface-50 px-4 py-24 sm:py-32"
      aria-labelledby="ig-heading"
    >
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent" aria-hidden="true"></div>

      <div class="mx-auto max-w-7xl">
        <!-- Header -->
        <div class="mb-12 flex flex-col sm:flex-row sm:items-end justify-between gap-6">
          <div class="flex flex-col gap-3">
            <span class="font-mono text-xs font-medium uppercase tracking-widest text-electric-light">
              // Instagram
            </span>
            <h2 id="ig-heading" class="text-3xl font-bold text-white sm:text-4xl">
              Síguenos en Instagram
            </h2>
            <p class="max-w-md text-slate-400 text-sm">
              Builds, sesiones de tune, swaps en proceso y resultados reales.
              Todo lo que ocurre en el taller, documentado.
            </p>
          </div>

          <!-- Profile card -->
          <a
            href="https://www.instagram.com/jntuned_cl"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-xl border border-surface-200 bg-surface px-5 py-4 transition-all duration-200 hover:border-electric/40 hover:bg-surface-100 flex-shrink-0"
          >
            <!-- Avatar placeholder con gradiente Instagram -->
            <div class="relative h-14 w-14 flex-shrink-0 rounded-full p-[2px]" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
              <div class="flex h-full w-full items-center justify-center rounded-full bg-surface font-mono text-sm font-bold text-white">
                JN
              </div>
            </div>
            <div class="flex flex-col gap-0.5">
              <span class="font-semibold text-white text-sm group-hover:text-electric-light transition-colors">@jntuned_cl</span>
              <span class="text-xs text-slate-500">Ver perfil completo</span>
              <div class="flex items-center gap-1 mt-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-electric-light" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
                <span class="text-xs text-electric-light font-medium">Seguir</span>
              </div>
            </div>
          </a>
        </div>

        <!-- Grid de posts Instagram -->
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-6">
          {[
            '/ig-post-1.jpg.jpeg',
            '/ig-post-2.jpg.jpeg',
            '/ig-post-3.jpg.jpeg',
            '/ig-post-4.jpg.jpeg',
            '/ig-post-5.jpg.jpeg',
            '/ig-post-6.jpg.jpeg',
          ].map((src, i) => (
            <a
              href="https://www.instagram.com/jntuned_cl"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative aspect-square overflow-hidden rounded-lg border border-surface-200 bg-surface-100"
              aria-label={`Ver post ${i + 1} en Instagram`}
            >
              <img
                src={src}
                alt={`JNTUNED Instagram post ${i + 1}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <!-- Overlay hover -->
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-300 flex items-center justify-center">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 drop-shadow-lg" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.5" fill="white"/>
                </svg>
              </div>
            </a>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-8 flex justify-center">
          <a
            href="https://www.instagram.com/jntuned_cl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded border border-surface-200 px-6 py-2.5 text-sm font-medium text-slate-300 transition-all duration-200 hover:border-electric/40 hover:text-white"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
            Ver todos los posts en Instagram
          </a>
        </div>
      </div>

      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent" aria-hidden="true"></div>
    </section>

    <!-- ═══════════════════════════════════════════════
         FORMULARIO DE CONTACTO
    ═══════════════════════════════════════════════ -->
    <section
      id="contacto"
      class="relative border-t border-surface-100 px-4 py-24 sm:py-32"
      aria-labelledby="contacto-heading"
    >
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-electric/30 to-transparent" aria-hidden="true"></div>

      <div class="mx-auto max-w-3xl">
        <header class="mb-12 flex flex-col gap-3 text-center">
          <span class="font-mono text-xs font-medium uppercase tracking-widest text-electric-light">
            // Contacto
          </span>
          <h2 id="contacto-heading" class="text-3xl font-bold text-white sm:text-4xl">
            Cotiza tu proyecto
          </h2>
          <p class="text-slate-400">
            Completa el formulario con los datos de tu vehículo y el servicio que necesitas.
            Respondemos en menos de 24 horas con una evaluación técnica.
          </p>
        </header>

        <!-- Form -->
        <form
          id="contact-form"
          class="flex flex-col gap-5 rounded-xl border border-surface-200 bg-surface-50 p-6 sm:p-8"
          novalidate
          aria-label="Formulario de cotización"
        >
          <!-- Nombre -->
          <div class="flex flex-col gap-1.5">
            <label for="nombre" class="text-sm font-medium text-slate-300">
              Nombre <span class="text-electric-light" aria-label="requerido">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              autocomplete="name"
              required
              minlength="2"
              placeholder="Tu nombre completo"
              class="rounded border border-surface-200 bg-surface px-4 py-2.5 text-sm text-white placeholder-slate-600 outline-none ring-0 transition-all focus:border-electric focus:ring-1 focus:ring-electric/50 aria-[invalid=true]:border-red-500"
              aria-describedby="nombre-error"
            />
            <span id="nombre-error" class="hidden text-xs text-red-400" role="alert"></span>
          </div>

          <!-- Vehículo / Motor -->
          <div class="flex flex-col gap-1.5">
            <label for="vehiculo" class="text-sm font-medium text-slate-300">
              Vehículo / Motor <span class="text-electric-light" aria-label="requerido">*</span>
            </label>
            <input
              type="text"
              id="vehiculo"
              name="vehiculo"
              required
              minlength="3"
              placeholder="Ej: Nissan Sentra B14 · SR20DET · 1996"
              class="rounded border border-surface-200 bg-surface px-4 py-2.5 text-sm text-white placeholder-slate-600 outline-none transition-all focus:border-electric focus:ring-1 focus:ring-electric/50 font-mono aria-[invalid=true]:border-red-500"
              aria-describedby="vehiculo-error"
            />
            <span id="vehiculo-error" class="hidden text-xs text-red-400" role="alert"></span>
          </div>

          <!-- Servicio -->
          <div class="flex flex-col gap-1.5">
            <label for="servicio" class="text-sm font-medium text-slate-300">
